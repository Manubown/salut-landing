# salut-landing — runtime environment (copy to .env for local runs)

# Port the SSR Node server listens on (container and local both use 4000).
# Coolify/Traefik terminates TLS and routes the domain to this port, so set
# Coolify's "Ports Exposes" to 4000 for this app.
PORT=4000
HOST=0.0.0.0

# The waitlist API (salut-api) this server proxies sign-ups to. Staging
# api.salut.bown.at, launch api.salut.com. Defaults to the staging URL if
# unset; for local dev against a locally-run API use http://localhost:3000.
WAITLIST_API_URL=https://api.salut.bown.at

NODE_ENV=production
