# salut-landing — runtime environment (copy to .env for local runs)

# Port the SSR Node server listens on. In the container this is 80 so
# Coolify/Traefik can route to it directly; locally use 4000.
PORT=4000
HOST=0.0.0.0

# Where the waitlist file (subscribers.jsonl) is persisted. In Coolify this
# is a persistent volume mounted at /data; locally it falls back to ./.data
# automatically if unset.
DATA_DIR=/data

NODE_ENV=production
